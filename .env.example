# Copy this file to .env and fill in local credentials.
# .env is ignored by Git and must not be committed.

# Required for real Tushare data fetching.
TUSHARE_TOKEN=your_tushare_token_here

# Optional Tushare throttling settings.
# TUSHARE_POINTS=2000
# TUSHARE_MAX_RPS=5

# Optional OpenAI-compatible LLM settings.
# NOTE: For the "LLM explanation" add-on this stays false (off by default).
#       But `fz mine agent` / `fz mine team` REQUIRE a ready LLM — set this to
#       true, otherwise load_llm_config(enabled=True) is force-disabled and the
#       agent aborts with "LLM 未配置".
FACTORZEN_LLM_ENABLED=false
FACTORZEN_LLM_BASE_URL=https://www.aiping.cn/api/v1
FACTORZEN_LLM_API_KEY=your_llm_api_key_here
FACTORZEN_LLM_MODEL=DeepSeek-V4-Pro
FACTORZEN_LLM_TIMEOUT_SECONDS=30
FACTORZEN_LLM_MAX_TOKENS=700
# AIPing enable_thinking toggle: true/enabled/on or false/disabled/off.
# FACTORZEN_LLM_THINKING=false
# Pin AIPing provider.only to avoid an unintended upstream fallback.
FACTORZEN_LLM_PROVIDER=DeepSeek
