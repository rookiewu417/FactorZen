# 复制本文件为 .env 并填入真实值
# cp .env.example .env

# ── Tushare Token（必填）────────────────────────────────────
# 在 https://tushare.pro/user/token 获取
TUSHARE_TOKEN=your_tushare_token_here

# ── 可选：限流与重试参数（默认值见 config/tushare_config.py）───
# TUSHARE_POINTS=2000     # 账户积分，影响部分接口权限提示
# TUSHARE_MAX_RPS=5       # 每秒最大请求数
