# pixi environments
.pixi/*
!.pixi/config.toml

# Virtual environments
.venv/
venv/

# Environment variables / secrets
.env
*.env.local

# Local market data and generated artifacts
data/*
!data/.gitkeep
tmp/

# Local agent/tool state
.claude/
CLAUDE.md
AGENTS.md

# Workspace is generated output by default.  Explicitly allow only versioned
# inputs/templates and placeholder directories; new runtime folders stay ignored.
workspace/*
!workspace/configs/
!workspace/configs/**
!workspace/factors/
!workspace/factors/**
!workspace/factor_evaluations/
workspace/factor_evaluations/*
!workspace/factor_evaluations/.gitkeep
!workspace/notebooks/
workspace/notebooks/*
!workspace/notebooks/.gitkeep
!workspace/runs/
workspace/runs/*
!workspace/runs/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# Temporary files
*.tmp
*.swp
*.swo

# Development notes
.sisyphus/notepads/
.superpowers/
docs/plans/

# Runtime logs and state
*.log
*.pid

# editable install artifacts
*.egg-info/
factor_research.egg-link

# 内部 SDD 设计文档(spec/plan),不对外发布
docs/superpowers/

# mypy daemon 状态文件
.dmypy.json
dmypy.json
.artifacts/
